{
  "name": "@oktopeak/clio-mcp",
  "version": "2.0.0",
  "mcpName": "io.github.oktopeak/clio-mcp",
  "description": "Open-source Model Context Protocol (MCP) server that connects Claude to Clio practice management. 26 tools covering matters, contacts, documents, tasks, notes, calendar, time entries, billing, users, and audit-log export. Supports stdio and HTTP/SSE transports. Built for law firms with ABA Opinion 512 audit logging and AES-256 encrypted token storage.",
  "main": "build/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc --project tsconfig.build.json && node -e \"require('fs').chmodSync('build/index.js', 0o755)\"",
    "start": "node build/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "bin": {
    "clio-mcp": "build/index.js"
  },
  "files": [
    "build",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oktopeak/clio-mcp.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "clio",
    "legal-tech",
    "law-firm",
    "legal-ai",
    "aba-opinion-512",
    "legal-automation",
    "practice-management",
    "oauth"
  ],
  "author": "Oktopeak <office@oktopeak.com> (https://oktopeak.com)",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/oktopeak/clio-mcp/issues"
  },
  "homepage": "https://github.com/oktopeak/clio-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
